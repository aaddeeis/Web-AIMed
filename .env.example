# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GITHUB_TOKEN: A Personal Access Token (classic or fine-grained) with read/write access to repository contents.
GITHUB_TOKEN=

# GITHUB_REPO_OWNER: The GitHub username or organization name of the repository (e.g. "my-username").
GITHUB_REPO_OWNER=aaddeeis

# GITHUB_REPO_NAME: The GitHub repository name (e.g. "my-aimedcoe-website").
GITHUB_REPO_NAME=Web-AIMed

# GITHUB_REPO_BRANCH: Optional. Defaults to "main" if not specified.
GITHUB_REPO_BRANCH=main

# GITHUB_FILE_PATH: Optional. The path inside the repository where the file should be saved. Defaults to "cms_data.json".
GITHUB_FILE_PATH=cms_data.json

# SUPABASE_URL: The public URL of your Supabase project (from Project Settings > API).
SUPABASE_URL=

# SUPABASE_SERVICE_ROLE_KEY: The secret service role key (bypass RLS for server operations).
SUPABASE_SERVICE_ROLE_KEY=

# SUPABASE_ANON_KEY: The public anon key (for client-side subscriptions and loads).
SUPABASE_ANON_KEY=

# VERCEL_DEPLOY_HOOK: The HTTPS POST trigger URL from Vercel to rebuild and update the production website.
VERCEL_DEPLOY_HOOK=

